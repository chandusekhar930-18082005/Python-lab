class Solution:
    def findMedianSortedArrays(self, nums1: List[int], nums2: List[int]) -> float:
        # Ensure nums1 is the shorter array to optimize binary search range
        if len(nums1) > len(nums2):
            nums1, nums2 = nums2, nums1
            
        m, n = len(nums1), len(nums2)
        low, high = 0, m
        total_half = (m + n + 1) // 2
        
        while low <= high:
            partition_x = (low + high) // 2
            partition_y = total_half - partition_x
            
            # Boundary conditions: use -infinity/infinity if partition is at edges
            max_left_x = nums1[partition_x - 1] if partition_x > 0 else float('-inf')
            min_right_x = nums1[partition_x] if partition_x < m else float('inf')
            
            max_left_y = nums2[partition_y - 1] if partition_y > 0 else float('-inf')
            min_right_y = nums2[partition_y] if partition_y < n else float('inf')
            
            if max_left_x <= min_right_y and max_left_y <= min_right_x:
                # Correct partition found
                if (m + n) % 2 == 0:
                    return (max(max_left_x, max_left_y) + min(min_right_x, min_right_y)) / 2.0
                else:
                    return float(max(max_left_x, max_left_y))
            
            elif max_left_x > min_right_y:
                # We are too far right in nums1, move left
                high = partition_x - 1
            else:
                # We are too far left in nums1, move right
                low = partition_x + 1
